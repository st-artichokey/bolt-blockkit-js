{
  "name": "retrorun",
  "version": "1.0.0",
  "description": "A Slack Bolt app demonstrating Block Kit UI for team retrospectives",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "dev": "node --watch app.js",
    "lint": "npx @biomejs/biome check *.js listeners",
    "lint:fix": "npx @biomejs/biome check --write *.js listeners",
    "start": "node app.js",
    "seed": "node scripts/seed-retros.js",
    "seed:members": "node scripts/seed-members.js",
    "seed:projects": "node scripts/seed-projects.js",
    "seed:submissions": "node scripts/seed-retro-submissions.js",
    "teardown": "node scripts/teardown.js",
    "test": "node --test 'tests/**/*.spec.js' 'tests/*.spec.js'"
  },
  "author": "Slack Technologies, LLC",
  "license": "MIT",
  "keywords": [
    "slack",
    "bolt",
    "block-kit",
    "retrospective",
    "slackapi"
  ],
  "dependencies": {
    "@slack/bolt": "^4.6.0",
    "dotenv": "^17.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@slack/cli-hooks": "^1.3.1",
    "esmock": "^2.7.3"
  }
}
